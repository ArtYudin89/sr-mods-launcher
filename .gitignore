# PyInstaller
/build/
/dist/
/webui/build/
/webui/dist/
/webui/_*.log

# Транзитные артефакты тестов/дизайна (регенерируются, в репо не нужны)
/webui/screenshots_pw/
/webui/design_mockups/
# spec нового UI — коммитим (рецепт сборки), остальные .spec игнорируем
# (секрета в spec нет — токен в gitignored embedded_secrets.py)
*.spec
!/webui/SRModsLauncher.spec
!/webui/SRModsLauncher-RWT.spec

# Артефакт релиза (пересобирается, кладётся в GitHub Release)
/SRModsLauncher-source.zip

# Вшитый ключ для тестовых сборок (RWT) — СЕКРЕТ, не коммитить
/embedded_secrets.py

# Python
__pycache__/
*.pyc

# Runtime-данные лаунчера (создаются при запуске)
/profiles/
launcher_config.json

# Локальная папка модов (если запускают из каталога лаунчера)
/Mods/
_dl.zip
_chunk_*
_*_code.zip

# Локальная раздача RWT (exe со вшитым токеном) — НЕ коммитить
/RWT-раздача/
